#include <stdio.h>
#include <string.h>

#define MAX 100

// MNT structure
struct MNT {
    char name[20];
    int mdt_index;
};

struct MNT mnt[MAX];
char mdt[MAX][100];
char ala[MAX][20];

int mntc = 0, mdtc = 0;

// Search parameter in ALA
int searchALA(char *param, int size) {
    for (int i = 0; i < size; i++) {
        if (strcmp(ala[i], param) == 0)
            return i;
    }
    return -1;
}

int main() {
    int n;
    char lines[MAX][100];

    printf("Enter number of lines:\n");
    scanf("%d", &n);
    getchar(); // clear buffer

    printf("Enter source program:\n");
    for (int i = 0; i < n; i++) {
        fgets(lines[i], sizeof(lines[i]), stdin);
    }

    for (int i = 0; i < n; i++) {
        char word1[20], word2[50];

        sscanf(lines[i], "%s %s", word1, word2);

        // Check MACRO
        if (strcmp(word1, "MACRO") == 0) {

            i++; // move to prototype line
            sscanf(lines[i], "%s %s", word1, word2);

            // Store in MNT
            strcpy(mnt[mntc].name, word1);
            mnt[mntc].mdt_index = mdtc;
            mntc++;

            // Process parameters into ALA
            int ala_size = 0;
            char params[50];
            strcpy(params, word2);

            char *token = strtok(params, ",");
            while (token != NULL) {
                strcpy(ala[ala_size++], token);
                token = strtok(NULL, ",");
            }

            // Store prototype in MDT
            sprintf(mdt[mdtc++], "%s %s", word1, word2);

            // Process macro body
            while (1) {
                i++;
                if (strstr(lines[i], "MEND") != NULL) {
                    strcpy(mdt[mdtc++], "MEND");
                    break;
                }

                char temp[100] = "";
                char copy[100];
                strcpy(copy, lines[i]);

                char *tok = strtok(copy, " ,\n");

                while (tok != NULL) {
                    int index = searchALA(tok, ala_size);

                    if (index != -1) {
                        char buf[10];
                        sprintf(buf, "#%d", index);
                        strcat(temp, buf);
                    } else {
                        strcat(temp, tok);
                    }
                    strcat(temp, " ");
                    tok = strtok(NULL, " ,\n");
                }

                strcpy(mdt[mdtc++], temp);
            }
        }
        else {
            // Print non-macro lines (intermediate code)
            printf("%s", lines[i]);
        }
    }

    // Print MDT
    printf("\n\nMDT (Macro Definition Table):\n");
    for (int i = 0; i < mdtc; i++) {
        printf("%d\t%s\n", i, mdt[i]);
    }

    // Print MNT
    printf("\nMNT (Macro Name Table):\n");
    for (int i = 0; i < mntc; i++) {
        printf("%d\t%s\t%d\n", i, mnt[i].name, mnt[i].mdt_index);
    }

    return 0;
}


